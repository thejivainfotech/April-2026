{% schema %}
{
  "name": "Orthotics Hero Gradient",
  "settings": [
    {
      "type": "text",
      "id": "top_label",
      "label": "Top Label",
      "default": "Board-Certified Podiatrist Designed"
    },

    {
      "type": "text",
      "id": "heading_1",
      "label": "Heading Line 1",
      "default": "Structure That Corrects."
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading Line 2 (Gradient)",
      "default": "Not Foam That Copes."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Designed by Dr. Mitchell Wachtel, DPM — a board-certified podiatrist with 25+ years of clinical practice."
    },

    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Right Image"
    },
{
  "type": "image_picker",
  "id": "doctor_icon",
  "label": "Doctor Icon (Badge Icon)"
},

    {
      "type": "text",
      "id": "doctor_name",
      "label": "Doctor Name",
      "default": "Dr. Mitchell Wachtel, DPM"
    },
    {
      "type": "text",
      "id": "doctor_title",
      "label": "Doctor Title",
      "default": "Board Certified Podiatrist"
    },

    {
      "type": "text",
      "id": "btn1_text",
      "label": "Primary Button",
      "default": "Shop OTC Orthotics - $49.99"
    },
    {
      "type": "url",
      "id": "btn1_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn2_text",
      "label": "Secondary Button",
      "default": "Custom Orthotics - $299"
    },
    {
      "type": "url",
      "id": "btn2_link",
      "label": "Secondary Button Link"
    },

    {
      "type": "text",
      "id": "feature_1",
      "label": "Feature 1",
      "default": "30-Day Guarantee"
    },
    {
      "type": "text",
      "id": "feature_2",
      "label": "Feature 2",
      "default": "Board-Certified DPM"
    },
    {
      "type": "text",
      "id": "feature_3",
      "label": "Feature 3",
      "default": "Free Shipping $75+"
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#0c2d48"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#b0c4d4"
    },

    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient Color 1",
      "default": "#00c2a8"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient Color 2",
      "default": "#00e0b8"
    },

    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    },

    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 10,
      "default": 80,
      "label": "Padding Top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 10,
      "default": 80,
      "label": "Padding Bottom"
    }
  ],
  "presets": [
    {
      "name": "Orthotics Hero Gradient"
    }
  ]
}
{% endschema %}

<section 
  class="hero-gradient-section"
  style="
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="hero-container">

    <!-- LEFT -->
    <div class="hero-left">

      {% if section.settings.top_label != blank %}
        <div class="hero-top-label">
          <span class="dot"></span>
          {{ section.settings.top_label }}
        </div>
      {% endif %}

      <h1>
        <span class="heading-normal">
          {{ section.settings.heading_1 }}
        </span><br>

        <span class="heading-gradient">
          {{ section.settings.heading_2 }}
        </span>
      </h1>

      <p>{{ section.settings.description }}</p>

      <div class="hero-buttons">
        <a href="{{ section.settings.btn1_link }}" class="btn-primary">
          {{ section.settings.btn1_text }}
        </a>

        <a href="{{ section.settings.btn2_link }}" class="btn-secondary">
          {{ section.settings.btn2_text }}
        </a>
      </div>

      <!-- FEATURES -->
      <div class="hero-features">
        {% if section.settings.feature_1 != blank %}
          <div class="feature-item">
            <span class="icon"><svg width="14" height="17" viewBox="0 0 14 17" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M6.75 15.801C6.75 15.801 12.75 12.801 12.75 8.30103V3.05103L6.75 0.801025L0.75 3.05103V8.30103C0.75 12.801 6.75 15.801 6.75 15.801Z" stroke="#00A657" stroke-width="1.5"/>
</svg>
</span>
            {{ section.settings.feature_1 }}
          </div>
        {% endif %}

        {% if section.settings.feature_2 != blank %}
          <div class="feature-item">
            <span class="icon"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
<g opacity="0.6" clip-path="url(#clip0_23_9233)">
<path d="M16.5 8.31002V9.00002C16.4991 10.6173 15.9754 12.191 15.007 13.4864C14.0386 14.7818 12.6775 15.7294 11.1265 16.1879C9.57557 16.6465 7.91794 16.5914 6.40085 16.031C4.88376 15.4705 3.58849 14.4346 2.70822 13.0778C1.82795 11.721 1.40984 10.1161 1.51626 8.50226C1.62267 6.88844 2.24791 5.35227 3.29871 4.12283C4.34951 2.89338 5.76959 2.03656 7.34714 1.68013C8.92469 1.3237 10.5752 1.48677 12.0525 2.14502" stroke="#00A657" stroke-width="1.5"/>
<path d="M16.5 3L9 10.5075L6.75 8.2575" stroke="#00A657" stroke-width="1.5"/>
</g>
<defs>
<clipPath id="clip0_23_9233">
<rect width="18" height="18" fill="white"/>
</clipPath>
</defs>
</svg>
</span>
            {{ section.settings.feature_2 }}
          </div>
        {% endif %}

        {% if section.settings.feature_3 != blank %}
          <div class="feature-item">
            <span class="icon"><svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
<g opacity="0.6">
<path d="M12 2.25H0.75V12H12V2.25Z" stroke="#00A657" stroke-width="1.5"/>
<path d="M12 6H15L17.25 8.25V12H12V6Z" stroke="#00A657" stroke-width="1.5"/>
<path d="M4.125 15.75C5.16053 15.75 6 14.9105 6 13.875C6 12.8395 5.16053 12 4.125 12C3.08947 12 2.25 12.8395 2.25 13.875C2.25 14.9105 3.08947 15.75 4.125 15.75Z" stroke="#00A657" stroke-width="1.5"/>
<path d="M13.875 15.75C14.9105 15.75 15.75 14.9105 15.75 13.875C15.75 12.8395 14.9105 12 13.875 12C12.8395 12 12 12.8395 12 13.875C12 14.9105 12.8395 15.75 13.875 15.75Z" stroke="#00A657" stroke-width="1.5"/>
</g>
</svg>
</span>
            {{ section.settings.feature_3 }}
          </div>
        {% endif %}
      </div>

    </div>

    <!-- RIGHT -->
    <div class="hero-right">
      {% if section.settings.hero_image %}
        <div class="image-card">
          <img src="{{ section.settings.hero_image | img_url: '600x' }}">

          {% comment %} <div class="doctor-info">
            <strong>{{ section.settings.doctor_name }}</strong><br>
            <small>{{ section.settings.doctor_title }}</small>
          </div> {% endcomment %}
          <div class="doctor-info">
  <div class="doctor-badge">
    
    {% if section.settings.doctor_icon %}
      <div class="doctor-icon">
        <img src="{{ section.settings.doctor_icon | img_url: '100x' }}">
      </div>
    {% endif %}

    <div class="doctor-text">
      <strong>{{ section.settings.doctor_name }}</strong>
      <span>{{ section.settings.doctor_title }}</span>
    </div>

  </div>
</div>
        </div>
      {% endif %}
    </div>

  </div>
</section>

<style>
.doctor-info {
  position: absolute;
  bottom: 15px;
  left: 15px;
  right: 15px;
}

.doctor-badge {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 18px;
  border-radius: 14px;

  background: rgba(20, 40, 60, 0.55);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);

  color: #fff;
}

.doctor-icon {
  min-width: 42px;
  border-radius: 50%;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.doctor-icon img {
  width: 60%;
  height: 60%;
  object-fit: contain;
}

.doctor-text strong {
  display: block;
  font-size: 14px;
  font-weight: 600;
}

.doctor-text span {
  font-size: 12px;
  opacity: 0.5;
}

.hero-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1200px;
  margin: auto;
  gap: 50px;
  flex-wrap: wrap;
}

.hero-left {
  flex: 1;
}

.hero-top-label {
        padding: 10px 16px;
        border: 1px solid #00A6571F;
        border-radius: 32px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #7A90A8;
        margin-bottom: 15px;
        background-color: #00A6570f;
}

.hero-top-label .dot {
    width: 8px;
    height: 8px;
    background: #00A657;
    border-radius: 4px;
    box-shadow: 0 0 10px;
}

.hero-left h1 {
  font-size: 80px;
  font-weight: 800;
  line-height: 88px;
  margin: 0;
  color: #E8EDF2;
}

.heading-normal {
  color: {{ section.settings.heading_color }};
}

.heading-gradient {
  background: linear-gradient(
    90deg,
    {{ section.settings.gradient_color_1 }},
    {{ section.settings.gradient_color_2 }}
  );
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-left p {
  margin-top: 20px;
  color: {{ section.settings.text_color }};
  font-size: 18px;
  max-width: 500px;
}

.hero-buttons {
  margin-top: 30px;
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
}

.btn-primary {
  background: linear-gradient(
    90deg,
    {{ section.settings.gradient_color_1 }},
    {{ section.settings.gradient_color_2 }}
  );
  color: {{ section.settings.btn_text }};
  padding: 16px 38px;
  border-radius: 30px;
  text-decoration: none;
}

.btn-secondary {
  border: 1px solid #ffffff20;
  color: #fff;
  padding: 16px 38px;
  border-radius: 30px;
  text-decoration: none;
}

.hero-features {
  display: flex;
  gap: 20px;
  margin-top: 25px;
  flex-wrap: wrap;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: #7A90A8;
}

.hero-right {
  flex: 1;
  display: flex;
  justify-content: center;
}

.image-card {
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  max-width: 480px;
}

.image-card img {
  width: 100%;
  display: block;
}

 

/* MOBILE */
@media (max-width: 768px) {
  .hero-gradient-section {
    padding-top: 90px !important;
  }
  .hero-left h1 {
    font-size: 34px;
    line-height: 40px;
    text-align: left;
    padding-inline: 20px;
  }
  .hero-top-label {
    margin-inline: 20px;
    width: 90%;
  }
  .hero-left p {
    text-align: left;
    padding-inline: 20px;
  }
  .hero-buttons {
    justify-content: center;
  }
  .btn-primary {
    width: 100%;
    margin-inline: 20px;
  }
  .btn-secondary {
    width: 100%;
    margin-inline: 20px;
  }
  .hero-container {
    flex-direction: column-reverse;
    text-align: center;
  }

  .hero-features {
    justify-content: left;
    margin-inline: 20px;
  }
  .image-card {
    padding-inline: 20px;
  }
  .doctor-badge {
    margin-inline: 20px;
  }
  .doctor-text {
    text-align: left;
  }
}
</style>
