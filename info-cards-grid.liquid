{%- style -%}
  .info-cards-{{ section.id }} {
    padding: 60px 20px;
    background-color: {{ section.settings.bg_color }};
    text-align: center;
  }
  .info-cards__header { margin-bottom: 60px; }
  .info-cards__subtitle { 
    color: #00A657; 
    font-size: 12px; 
    text-transform: uppercase; 
    letter-spacing: 2px;
    font-weight: 600;
  }
  .info-cards__title { 
    font-size: 56px; 
    margin: 10px 0; 
    color: #01203F;
    font-weight: 800;
  }
  .info-cards__description { 
    margin: 0 auto; 
    color: #3A4554;
    line-height: 30px;
    font-size: 18px;
  }
  .info-cards__grid {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
  }
  .info-card {
    flex: 1;
    min-width: 300px;
    padding: 40px 30px;
    border-radius: 28px;
    text-align: left;
    display: flex;
    flex-direction: column;
  }
  .info-card__icon { width: 40px; height: 40px; margin-bottom: 20px; border-radius: 8px; display: flex; align-items: center; justify-content: center; }
  .info-card__label { font-size: 12px; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; }
  .info-card__heading { font-size: 24px; margin-top: 10px; margin-bottom: 0px; line-height: 28px; font-weight: 800; }
  .info-card__text { font-size: 15px; line-height: 1.5; opacity: 0.9; }
.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  @media (max-width: 768px) {
    .info-cards__title { font-size: 32px; }
    .info-card { min-width: 100%; }
    .info-card__heading { font-size: 18px; }
  }
{%- endstyle -%}

<section class="info-cards-{{ section.id }} section-{{ section.id }}-padding">
  <div class="info-cards__header">
    <p class="info-cards__subtitle">{{ section.settings.subtitle }}</p>
    <h2 class="info-cards__title">{{ section.settings.title }}</h2>
    <div class="info-cards__description">{{ section.settings.desc }}</div>
  </div>

  <div class="info-cards__grid">
    {%- for block in section.blocks -%}
      <div class="info-card" style="background-color: {{ block.settings.card_bg }}; color: {{ block.settings.text_color }};">
        
        {%- if block.settings.step_number != blank -%}
          <span class="info-card__number">
            {{ block.settings.step_number }}
          </span>
        {%- endif -%}

        <div class="info-card__icon" style="background-color: rgba(255,255,255,0.1);">
           {% if block.settings.icon_svg != blank %}
             {{ block.settings.icon_svg }}
           {% endif %}
        </div>
        <span class="info-card__label" style="color: {{ block.settings.accent_color }}; text-transform: uppercase; display: block; margin-bottom: 10px;">{{ block.settings.label }}</span>
        <h3 class="info-card__heading">{{ block.settings.heading }}</h3>
        <p class="info-card__text">{{ block.settings.content }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Info Cards Grid",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f4f4f4" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "THE INDUSTRY IS BROKEN" },
    { "type": "text", "id": "title", "label": "Main Title", "default": "We Fixed It." },
    { "type": "richtext", "id": "desc", "label": "Description" },
    { 
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "step_number", "label": "Step Number", "default": "01" },
        { "type": "color", "id": "card_bg", "label": "Card Background", "default": "#001e3c" },
        { "type": "color", "id": "text_color", "label": "Text Color", "default": "#ffffff" },
        { "type": "color", "id": "accent_color", "label": "Label Color", "default": "#3498db" },
        { "type": "html", "id": "icon_svg", "label": "Icon SVG Code" },
        { "type": "text", "id": "label", "label": "Card Label", "default": "STEP ONE" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Heading here" },
        { "type": "textarea", "id": "content", "label": "Content" }
      ]
    }
  ],
  "presets": [
    { "name": "Info Cards Grid" }
  ]
}
{% endschema %}
