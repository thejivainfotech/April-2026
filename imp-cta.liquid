{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .imp-wrapper {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
    padding: 0 20px;
  }

  .imp-title {
    font-size: 26px;
    font-weight: 800;
    color: #01203F;
    margin-bottom: 15px;
    line-height: 29px;
  }

   .imp-text {
        font-size: 15px;
        color: #3A4554;
        line-height: 25px;
        margin-bottom: 30px;
        max-width: 475px;
        margin-left: auto;
        margin-right: auto;
    }

.imp-button {
    display: inline-block;
    padding: 16px 38px;
    font-size: 14px;
    font-weight: 500;
    color: #ffffff;
    text-decoration: none;
    border-radius: 60px;
    background: linear-gradient(90deg, #00A657 0%, #00AEEC 100%);
    transition: all 0.3s ease;
    margin-bottom: 25px;
    box-shadow: 0px 2px 12px 0px #00A6574D;
}

  .imp-badges {
    display: flex;
    justify-content: center;
    gap: 15px 25px;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
  }

  .imp-badge-item {
    font-size: 11px;
    color: #6A7585;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .imp-badge-item svg {
    width: 11px;
    height: 11px;
    flex-shrink: 0;
  }

  .imp-contact {
    font-size: 12px;
    color: #6A7585;
  }

  .imp-contact a {
    color: #00A657;
    font-weight: 700;
    text-decoration: none;
  }
   @media screen and (max-width: 767px) { 
    .imp-title {
        font-size: 18px;
        line-height: 21px;
    }
   }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding">
  <div class="imp-wrapper">
    
    {% if section.settings.heading != blank %}
      <h2 class="imp-title">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <div class="imp-text">{{ section.settings.subtext }}</div>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link }}" class="imp-button">
        {{ section.settings.button_label }} — {{ section.settings.price }}
      </a>
    {% endif %}

    <ul class="imp-badges">
      {%- for block in section.blocks -%}
        <li class="imp-badge-item" {{ block.shopify_attributes }}>
          {% if block.settings.svg_code != blank %}
            {{ block.settings.svg_code }}
          {% else %}
            <svg width="14" height="14" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
          {% endif %}
          {{ block.settings.badge_text }}
        </li>
      {%- endfor -%}
    </ul>

    {% if section.settings.contact_text != blank %}
      <div class="imp-contact">
        {{ section.settings.contact_text }} 
        {% if section.settings.contact_link_text != blank %}
          <a href="{{ section.settings.contact_url }}">
            {{ section.settings.contact_link_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Imp CTA Banner",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f9f8f3"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Your Kit Ships in 3 Days. Your Customs Arrive in About 2 Weeks."
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>That's it. No office visit. No phone call with your insurance company.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Get Your Impression Kit"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price Tag",
      "default": "$299.99"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Contact Settings"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact Label",
      "default": "Questions? Call us at"
    },
    {
      "type": "text",
      "id": "contact_link_text",
      "label": "Link Text (Phone or Page)",
      "default": "(978) 837-9705"
    },
    {
      "type": "url",
      "id": "contact_url",
      "label": "Contact URL/Phone",
      "info": "Use 'tel:123456' for phone or select a page."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "html",
          "id": "svg_code",
          "label": "SVG Code",
          "info": "Paste SVG code here. Leave blank for default checkmark."
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text",
          "default": "90-day fit guarantee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Imp CTA Banner",
      "blocks": [
        { "type": "badge", "settings": { "badge_text": "90-day fit guarantee" } },
        { "type": "badge", "settings": { "badge_text": "Free shipping both ways" } }
      ]
    }
  ]
}
{% endschema %}
