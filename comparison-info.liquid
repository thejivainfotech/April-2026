<section class="cpr-custom-section section-{{ section.id }}-padding">
  <div class="cpr-container">
    <div class="cpr-grid">
      
      {% comment %} Left Side: Images {% endcomment %}
      <div class="cpr-image-column">
        <div class="cpr-image-wrapper">
          <div class="cpr-image-card">
            {% if section.settings.image_1 != blank %}
              <img src="{{ section.settings.image_1 | image_url: width: 800 }}" alt="{{ section.settings.image_1.alt }}" loading="lazy">
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'cpr-placeholder' }}
            {% endif %}
            <span class="cpr-badge">{{ section.settings.badge_1 }}</span>
          </div>
          
          <div class="cpr-image-card">
            {% if section.settings.image_2 != blank %}
              <img src="{{ section.settings.image_2 | image_url: width: 800 }}" alt="{{ section.settings.image_2.alt }}" loading="lazy">
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'cpr-placeholder' }}
            {% endif %}
            <span class="cpr-badge cpr-badge-accent">{{ section.settings.badge_2 }}</span>
          </div>
        </div>
      </div>

      {% comment %} Right Side: Content {% endcomment %}
      <div class="cpr-content-column">
        <span class="cpr-subheading">{{ section.settings.subheading }}</span>
        <h2 class="cpr-heading">{{ section.settings.heading }}</h2>
        <div class="cpr-description">{{ section.settings.description }}</div>
        
        <ul class="cpr-feature-list">
          {% for block in section.blocks %}
            <li class="cpr-feature-item" {{ block.shopify_attributes }}>
              <span class="cpr-check-icon">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="28" height="28" rx="8" fill="#E6F7EE"/>
                <path d="M18.6663 10.5L12.2497 16.9167L9.33301 14" stroke="#008A48" stroke-width="1.16667"/>
                </svg>
              </span>
              <div class="cpr-feature-text">
                <span class="cpr-feature-title">{{ block.settings.title }}</span> {{ block.settings.text }}
              </div>
            </li>
          {% endfor %}
        </ul>

        {% if section.settings.link_text != blank %}
          <div class="cpr-cta-wrapper">
            <a href="{{ section.settings.link_url }}" class="cpr-cta-link">
              {{ section.settings.link_text }} <span class="cpr-arrow"><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M3.33301 8H12.6663" stroke="#00A657" stroke-width="1.33333"/>
<path d="M8 3.3335L12.6667 8.00016L8 12.6668" stroke="#00A657" stroke-width="1.33333"/>
</svg>
</span>
            </a>
          </div>
        {% endif %}
      </div>

    </div>
  </div>
</section>

{% style %}
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.bg_color }};
}

.cpr-container { max-width: 1240px; margin: 0 auto; padding: 0 20px; }
.cpr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 50px; align-items: center; }
.cpr-image-wrapper { display: flex; gap: 15px; }
.cpr-image-card { position: relative; flex: 1; border-radius: 12px; overflow: hidden; }
.cpr-image-card img { width: 100%; height: auto; display: block; object-fit: cover; aspect-ratio: 0.85; }

.cpr-badge { position: absolute; bottom: 15px; left: 50%; transform: translateX(-50%); background: #00A65733; color: #008A48; padding: 6px 14px; border-radius: 20px; font-size: 10px; font-weight: 800; text-transform: uppercase; white-space: nowrap; }
.cpr-badge-accent { background: #00AEEC33; color: #00AEEC; padding: 6px 14px; font-size: 10px; letter-spacing: 1.39px; }

.cpr-subheading { color: #00AEEC; font-size: 11px; line-height: 17.95px; font-weight: 500; letter-spacing: 1.96px; text-transform: uppercase; display: block; margin-bottom: 10px; }
.cpr-heading { font-size: 56px; line-height: 61.6px; margin: 0 0 15px 0; color: #01203F; font-weight: 800; }
.cpr-description { font-size: 16px; color: #3A4554; margin-bottom: 25px; line-height: 28px; }

.cpr-feature-list { list-style: none; padding: 0; margin: 0 0 30px 0; }
.cpr-feature-item { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 15px; font-size: 14px; line-height: 1.4; }
.cpr-check-icon { flex-shrink: 0; margin-top: 2px; }
.cpr-feature-title { font-weight: 700; color: #081F3C; }

.cpr-cta-wrapper { margin-top: 20px; }
.cpr-cta-link { color: {{ section.settings.accent_color }}; font-weight: 600; text-decoration: none; font-size: 15px; display: inline-flex; align-items: center; gap: 5px; }
.cpr-arrow { font-size: 18px; transition: transform 0.2s ease; }
.cpr-cta-link:hover .cpr-arrow { transform: translateX(5px); }

@media (max-width: 768px) {
  .cpr-grid { grid-template-columns: 1fr; gap: 30px; }
  .cpr-heading { font-size: 32px; line-height: 35.2px; }
  .cpr-image-wrapper { flex-direction: row; }
}
{% endstyle %}

{% schema %}
{
  "name": "CPR Comparison",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f4f2ee" },
    { "type": "color", "id": "accent_color", "label": "Accent Color (Icon/Link)", "default": "#00D084" },
    { "type": "image_picker", "id": "image_1", "label": "Image 1" },
    { "type": "text", "id": "badge_1", "label": "Badge 1", "default": "One Shape Fits All" },
    { "type": "image_picker", "id": "image_2", "label": "Image 2" },
    { "type": "text", "id": "badge_2", "label": "Badge 2", "default": "Your Exact Foot Arch" },
    { "type": "text", "id": "subheading", "label": "Sub-heading", "default": "THE DIFFERENCE NOBODY TELLS YOU" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "There's a Reason Your Insoles Keep Failing" },
    { "type": "richtext", "id": "description", "label": "Description" },
    { "type": "text", "id": "link_text", "label": "Link Text", "default": "Not sure if you need custom? Take the 60-second quiz." },
    { "type": "url", "id": "link_url", "label": "Link URL" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Top Padding", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 5, "unit": "px", "label": "Bottom Padding", "default": 60 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "title", "label": "Bold Title", "default": "Overpronation" },
        { "type": "textarea", "id": "text", "label": "Description Text" }
      ]
    }
  ],
  "presets": [
    { 
      "name": "CPR Comparison Section",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
