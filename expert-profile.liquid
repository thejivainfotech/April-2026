<style>
 .expert-profile {
    position: relative;
    padding: 100px 0;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    font-family: inherit;
  }

  .expert-profile .container-expert {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 5;
  }

  .expert-profile .expert-grid {
    display: flex;
    align-items: stretch;
    gap: 80px;
  }

  /* Image Side */
  .expert-profile .expert-image-side {
    flex: 1;
    position: relative;
  }

  .expert-profile .main-img {
    width: 100%;
    height: auto;
    border-radius: 40px; /* Rounded corners like the screenshot */
    display: block;
    box-shadow: 0 20px 40px rgba(0,0,0,0.05);
  }

  /* Content Side */
  .expert-profile .expert-content-side {
    flex: 1.2;
  }

  .expert-profile .sub-heading {
    color: #00A657;
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.96px;
    display: block;
    margin-bottom: 15px;
  }

  .expert-profile .main-heading {
    font-size: 56px;
    line-height: 62px;
    color: #01203F;
    margin: 0 0 30px 0;
    font-weight: 800;
    max-width: 520px;
  }

  .expert-profile .quote-box {
    border-left: 3px solid; 
    border-image-source: linear-gradient(to bottom, #00A657, #00AEEC);
    border-image-slice: 1;
    padding-left: 25px;
    margin-bottom: 30px;
}

  .expert-profile .quote-text {
    font-size: 26px;
    line-height: 38px;
    font-style: italic;
    color: #01203F;
    margin: 0;
    font-weight: 500;
  }

  .expert-profile .description {
    font-size: 15px;
    line-height: 28px;
    color: #3A4554;
    margin-bottom: 25px;
  }

  /* Badges */
  .expert-profile .badge-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 15px;
  }

  .expert-profile .badge-item {
    background: #E6F7EE;
    color: #008A48;
    border: 1px solid #00A6571F;
    padding: 5px 12px;
    border-radius: 60px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
  }

  /* CTA Link */
  .expert-profile .expert-link {
    display: inline-flex;
    align-items: center;
    color: #00A657;
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    transition: transform 0.3s ease;
    line-height: 22px;
  }

  .expert-profile .expert-link span {
    margin-left: 8px;
    font-size: 20px;
  }

  /* Watermark */
  .expert-profile .watermark {
    position: absolute;
    bottom: -15px;
    right: 0;
    font-size: 130px;
    font-weight: 900;
    color: rgba(0, 0, 0, 0.03);
    z-index: 1;
    line-height: 1;
    pointer-events: none;
    user-select: none;
    opacity: 90%;
  }

  /* Responsive Design */
   @media (max-width: 991px) {
    .expert-profile .expert-grid {
      flex-direction: column;
      gap: 50px;
    }
    .expert-profile .main-heading {
      font-size: 32px;
      line-height: 35px;
    }
    .expert-profile .watermark {
      font-size: 100px;
      bottom: -30px;
    }
    .expert-profile .quote-text {
    font-size: 19px;
    line-height: 28px;
  }
  .expert-profile {
    padding: 80px 0;
  }
  }

</style>

<div class="expert-profile">
  <div class="container-expert">
    <div class="expert-grid">
      
      <div class="expert-image-side">
        {% if section.settings.expert_image != blank %}
          <img src="{{ section.settings.expert_image | image_url: width: 1000 }}" 
               alt="{{ section.settings.expert_name }}" 
               class="main-img" 
               loading="lazy">
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'main-img' }}
        {% endif %}
      </div>

      <div class="expert-content-side">
        <span class="sub-heading">{{ section.settings.sub_heading }}</span>
        <h2 class="main-heading">{{ section.settings.expert_name }}</h2>

        {% if section.settings.quote != blank %}
          <div class="quote-box">
            <h4 class="quote-text">"{{ section.settings.quote }}"</h4>
          </div>
        {% endif %}

        <div class="description">
          {{ section.settings.content }}
        </div>

        <div class="badge-wrapper">
          {% if section.settings.badge1 != blank %}<span class="badge-item">{{ section.settings.badge1 }}</span>{% endif %}
          {% if section.settings.badge2 != blank %}<span class="badge-item">{{ section.settings.badge2 }}</span>{% endif %}
          {% if section.settings.badge3 != blank %}<span class="badge-item">{{ section.settings.badge3 }}</span>{% endif %}
        </div>

        {% if section.settings.link_text != blank %}
          <a href="{{ section.settings.link_url }}" class="expert-link">
            {{ section.settings.link_text }} <span><svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
<path d="M3.33325 8H12.6666" stroke="#00A657" stroke-width="1.33333"/>
<path d="M8 3.3335L12.6667 8.00016L8 12.6668" stroke="#00A657" stroke-width="1.33333"/>
</svg>
</span>
          </a>
        {% endif %}
      </div>

    </div>
  </div>

  {% if section.settings.watermark_text != blank %}
    <div class="watermark">{{ section.settings.watermark_text }}</div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Expert Profile Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f4f4"
    },
    {
      "type": "image_picker",
      "id": "expert_image",
      "label": "Expert Image"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "MEET YOUR PODIATRIST"
    },
    {
      "type": "text",
      "id": "expert_name",
      "label": "Full Name",
      "default": "Dr. Mitchell Wachtel, DPM"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "I built this because I was tired of watching my patients spend money on products designed to fail them."
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Description",
      "default": "<p>Add your clinical experience details here.</p>"
    },
    {
      "type": "text",
      "id": "badge1",
      "label": "Badge 1",
      "default": "BOARD-CERTIFIED DPM"
    },
    {
      "type": "text",
      "id": "badge2",
      "label": "Badge 2",
      "default": "25+ YEARS CLINICAL"
    },
    {
      "type": "text",
      "id": "badge3",
      "label": "Badge 3",
      "default": "ACTIVE PRACTICE"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Read Dr. Wachtel's Full Story"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "text",
      "id": "watermark_text",
      "label": "Watermark Text",
      "default": "DPM"
    }
  ],
  "presets": [
    {
      "name": "Expert Profile Section"
    }
  ]
}
{% endschema %}
